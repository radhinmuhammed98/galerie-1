---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import ScrollVideo from '../../components/ScrollVideo.astro';
import Gallery from '../../components/Gallery.astro';
import Parallax3DSection from '../../components/Parallax3DSection.astro';
import Events from '../../components/Events.astro';
import History from '../../components/History.astro';
import Stats from '../../components/Stats.astro';
import Services from '../../components/Services.astro';
import ScrollDiptyque from '../../components/ScrollDiptyque.astro';
import MonogramSection from '../../components/MonogramSection.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout 
  title="Galerie des Orfèvres | Fine Silverware & Contemporary Art in Paris" 
  description="Explore Galerie des Orfèvres at 23 Place Dauphine. A prestigious Parisian gallery showcasing rare silverware, bold contemporary art, and exclusive exhibitions."
  lang="en"
>
  <Navigation lang="en" />

  <main>
    <Hero lang="en" />
    <ScrollVideo lang="en" />

    <Gallery lang="en" />

    <!-- 3D Parallax interstitial section -->
    <Parallax3DSection lang="en" />

    <Events lang="en" />

    <History lang="en" />

    <Stats lang="en" />
    <Services lang="en" />

    <!-- Cinematic diptych: 2 videos side by side, scrubbed in sync -->
    <ScrollDiptyque lang="en" />

    <!-- Monogram GO section with floating artworks -->
    <MonogramSection lang="en" />

    <!-- Contact CTA section -->
    <ContactCTA lang="en" />
  </main>

  <Footer lang="en" />
</BaseLayout>
