---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';
import HeroScrollIndicator from './HeroScrollIndicator.astro';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

const heroH1Lines = lang === 'en'
  ? ["A space for bold art", "and new ideas"]
  : ["Un espace pour l'art audacieux", "et les nouvelles idées"];
---

<section class="hero-scroll-section relative bg-noir-orfevre" id="hero">
  <!-- Conteneur sticky -->
  <div class="hero-scroll-pin sticky top-0 h-screen w-full overflow-hidden flex items-center justify-center">

    <!-- Perspective grid floor -->
    <div class="perspective-grid-floor" id="hero-grid-floor" aria-hidden="true"></div>

    <!-- Particules dorées -->
    <div id="hero-particles" class="absolute inset-0 z-[2] pointer-events-none opacity-40 mix-blend-screen"></div>

    <!-- Canvas image-sequence (inchangé) -->
    <canvas
      id="hero-sequence-canvas"
      class="hero-sequence-canvas absolute inset-0 h-full w-full md:inset-auto md:aspect-[16/9] md:w-[min(96vw,170vh)] md:max-h-[95vh] z-0 md:rounded-[20px] shadow-2xl border border-ivoire/10"
      style="opacity: 0;"
    ></canvas>

    <!-- Loader % -->
    <div id="hero-sequence-loader" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[4] text-ivoire/50 text-xs font-sans tracking-[0.3em] uppercase">
      <span id="hero-sequence-progress">0</span>%
    </div>

    <!-- OVERLAY 1 : H1 massif avec perspective wrapper -->
    <div class="hero-overlay-1 absolute inset-0 flex flex-col items-center justify-center text-center px-6 z-[3] pointer-events-none" style="perspective: var(--perspective-hero);">
      <h1 class="hero-h1 text-ivoire leading-[0.92] font-serif italic tracking-tight select-none px-4 max-w-5xl" style="font-size: clamp(4rem, 9.5vw, 12rem);">
        {heroH1Lines.map((line, i) => (
          <span class="hero-h1-line block overflow-hidden" data-line={i}>
            <span class="hero-h1-inner block" style="transform: perspective(1000px) rotateX(-35deg) translateZ(-200px); opacity: 0;">
              {line}
            </span>
          </span>
        ))}
      </h1>
    </div>

    <!-- Indicateur scroll -->
    <HeroScrollIndicator />

    <!-- OVERLAY 2 : Citation héritage -->
    <div class="hero-overlay-2 absolute inset-0 flex flex-col items-center justify-center text-center px-6 z-[3] pointer-events-none opacity-0">
      <h2 class="text-ivoire font-serif leading-[1.02] tracking-tight max-w-4xl px-4 select-none" style="font-size: clamp(2.8rem, 6vw, 8rem);">
        {t['heritage.text']}
      </h2>
    </div>

  </div>
</section>

<script>
  import { gsap } from "../lib/gsap-config";
  import { initScrollSequence } from "../lib/scroll-sequence";
  import { initParticles } from "./ParticlesBackground";
  import { splitText } from "../lib/text-reveal";

  const HERO_FRAME_COUNT = 100;
  const heroFramePath = (i: number) =>
    `/images/sequence/hero/frame_${String(i + 1).padStart(3, "0")}.webp`;

  if (typeof window !== "undefined") {
    const setup = () => {
      const canvas = document.getElementById("hero-sequence-canvas") as HTMLCanvasElement | null;
      const section = document.querySelector(".hero-scroll-section") as HTMLElement | null;
      const overlay1 = document.querySelector(".hero-overlay-1") as HTMLElement | null;
      const overlay2 = document.querySelector(".hero-overlay-2") as HTMLElement | null;
      const loader = document.getElementById("hero-sequence-loader");
      const progress = document.getElementById("hero-sequence-progress");
      const particlesContainer = document.getElementById("hero-particles");
      const gridFloor = document.getElementById("hero-grid-floor");
      const h1Inners = document.querySelectorAll<HTMLElement>(".hero-h1-inner");

      if (!canvas || !section || !overlay1 || !overlay2) return;

      const isMobile = window.matchMedia("(max-width: 767px), (pointer: coarse)").matches;
      section.style.height = isMobile ? "420vh" : "550vh";

      if (particlesContainer) initParticles(particlesContainer, { count: isMobile ? 40 : 80 });

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // --- 3D word entry animation sur le H1 ---
      if (!prefersReducedMotion && h1Inners.length) {
        gsap.to(Array.from(h1Inners), {
          rotateX: 0,
          translateZ: 0,
          opacity: 1,
          duration: 1.2,
          ease: "power4.out",
          stagger: 0.18,
          delay: 0.3,
          clearProps: "transform,opacity",
        });
      } else {
        h1Inners.forEach((el) => {
          el.style.opacity = "1";
          el.style.transform = "none";
        });
      }

      // --- Perspective grid floor reveal ---
      if (gridFloor && !prefersReducedMotion && !isMobile) {
        gsap.to(gridFloor, {
          opacity: 0.6,
          duration: 1.8,
          ease: "power2.out",
          delay: 0.6,
        });
      }

      if (prefersReducedMotion) {
        gsap.set(overlay1, { opacity: 1 });
        gsap.set(overlay2, { opacity: 0 });
      }

      // --- Magnetic field sur les lettres du H1 ---
      const h1 = document.querySelector<HTMLElement>(".hero-h1");
      if (h1 && !prefersReducedMotion && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        const lineSpans = h1.querySelectorAll<HTMLElement>(".block");
        const letters = Array.from(lineSpans).flatMap((line) => splitText(line, "letters"));
        const radius = 120;
        const maxAmp = 4;

        type LetterOrigin = { el: HTMLElement; cx: number; cy: number; tx: any; ty: any };
        let origins: LetterOrigin[] = [];
        const computeOrigins = () => {
          origins = letters.map((el) => {
            const r = el.getBoundingClientRect();
            return {
              el, cx: r.left + r.width / 2, cy: r.top + r.height / 2,
              tx: gsap.quickTo(el, "x", { duration: 0.5, ease: "power2.out" }),
              ty: gsap.quickTo(el, "y", { duration: 0.5, ease: "power2.out" }),
            };
          });
        };
        computeOrigins();
        window.addEventListener("resize", computeOrigins);

        let mx = -1e6, my = -1e6;
        window.addEventListener("mousemove", (e) => { mx = e.clientX; my = e.clientY; }, { passive: true });
        gsap.ticker.add(() => {
          for (const o of origins) {
            const dx = mx - o.cx; const dy = my - o.cy;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < radius) {
              const k = (1 - dist / radius) * maxAmp;
              o.tx((dx / dist) * k); o.ty((dy / dist) * k);
            } else { o.tx(0); o.ty(0); }
          }
        });
      }

      // --- Scroll sequence (canvas) inchangé ---
      initScrollSequence({
        canvas, section,
        framePath: heroFramePath,
        frameCount: HERO_FRAME_COUNT,
        loaderEl: loader,
        progressEl: progress,
        onProgress: (p) => {
          // Canvas opacity
          let cOpacity = 0;
          if (p < 0.10) cOpacity = 0;
          else if (p < 0.30) cOpacity = (p - 0.10) / 0.20;
          else if (p < 0.88) cOpacity = 1;
          else cOpacity = 1 - (p - 0.88) / 0.12;
          canvas.style.opacity = String(Math.max(0, Math.min(1, cOpacity)));

          // Grid floor fades out as canvas appears
          if (gridFloor && !isMobile) {
            gridFloor.style.opacity = String(Math.max(0, 0.6 * (1 - p / 0.25)));
          }

          // Overlay 1 : titre (3D recession + fade out)
          let o1 = 1;
          if (p < 0.10) o1 = 1;
          else if (p < 0.40) o1 = 1 - (p - 0.10) / 0.30;
          else o1 = 0;
          // 3D depth recession as it fades out
          const recZ = -80 * (1 - o1);
          gsap.set(overlay1, {
            opacity: o1,
            y: -50 * (1 - o1),
            rotateX: -8 * (1 - o1),
            z: recZ,
          });

          // Overlay 2 : citation héritage (3D entry from depth)
          let o2 = 0;
          if (p >= 0.45 && p < 0.65) o2 = (p - 0.45) / 0.20;
          else if (p >= 0.65 && p < 0.92) o2 = 1;
          else if (p >= 0.92) o2 = 1 - (p - 0.92) / 0.08;
          o2 = gsap.utils.clamp(0, 1, o2);
          gsap.set(overlay2, {
            opacity: o2,
            y: (1 - o2) * 80 - (p > 0.92 ? 50 * (p - 0.92) / 0.08 : 0),
            rotateX: -12 * (1 - o2),
            scale: 0.95 + 0.05 * o2,
          });
        },
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .hero-scroll-section h1,
  .hero-scroll-section h2 {
    font-weight: 300;
    text-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
  }

  .hero-h1-inner {
    will-change: transform, opacity;
    transform-origin: center bottom;
  }

  .hero-overlay-1,
  .hero-overlay-2 {
    transform-style: preserve-3d;
  }

  @media (max-width: 767px) {
    .hero-scroll-pin {
      height: 100svh;
      min-height: 100svh;
    }

    .hero-scroll-pin::after {
      content: "";
      position: absolute;
      inset: 70px 14px 22px;
      z-index: 1;
      pointer-events: none;
      border: 1px solid rgba(244, 239, 230, 0.10);
      background: linear-gradient(180deg, rgba(10, 10, 10, 0.06), rgba(10, 10, 10, 0.30));
      box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.30);
      backdrop-filter: blur(1px);
      -webkit-backdrop-filter: blur(1px);
      border-radius: 20px;
    }

    .hero-overlay-1,
    .hero-overlay-2 {
      padding-inline: 1rem;
    }

    .hero-h1 {
      font-size: clamp(3rem, 14vw, 5.5rem) !important;
      line-height: 0.95;
      text-wrap: balance;
    }

    .hero-overlay-2 h2 {
      font-size: clamp(2.4rem, 12vw, 4rem) !important;
      line-height: 1;
      text-wrap: balance;
    }

    #hero-sequence-loader {
      bottom: max(1.25rem, env(safe-area-inset-bottom));
      padding: 0.65rem 0.8rem;
      border: 1px solid rgba(212, 184, 134, 0.16);
      background: rgba(10, 10, 10, 0.42);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-radius: 12px;
    }
  }
</style>
