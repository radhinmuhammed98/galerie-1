---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

const stats = [
  { value: 75,  label: t['stats.exhibitions'], suffix: '+' },
  { value: 300, label: t['stats.projects'],    suffix: '+' },
  { value: 300, label: t['stats.artworks'],    suffix: '+' },
  { value: 30,  label: t['stats.visitors'],    suffix: 'K+' },
];
---

<section class="stats-section relative overflow-hidden" id="stats">

  <!-- Background: dark full-bleed -->
  <div class="max-w-[1800px] mx-auto px-6 md:px-16 py-24 md:py-36">

    <!-- Label -->
    <p class="stats-label font-sans text-[10px] uppercase tracking-[0.38em] text-or-fonce mb-16 md:mb-24 opacity-0 text-center">
      {lang === 'en' ? 'By the numbers' : 'En chiffres'}
    </p>

    <!-- Stats grid: 4 massive numbers -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-ivoire/[0.07]">
      {stats.map((stat, i) => (
        <div class="stat-item group relative flex flex-col items-center justify-center py-14 md:py-20 px-6 bg-noir-orfevre text-center overflow-hidden"
             data-stat-index={i}>

          <!-- Number + suffix -->
          <div class="stat-number-wrap relative flex items-baseline justify-center gap-1 mb-5"
               style="perspective: 600px;">
            <span
              class="stat-number font-serif text-or-fonce leading-none"
              data-target={stat.value}
              style="font-size: clamp(4.5rem, 9vw, 9rem);"
            >0</span>
            <span class="stat-suffix font-serif text-or-clair/70"
                  style="font-size: clamp(2.5rem, 4.5vw, 5rem); font-weight: 300;">{stat.suffix}</span>
          </div>

          <!-- SVG filament -->
          <svg viewBox="0 0 80 2" preserveAspectRatio="none" width="48" height="2"
               class="stat-underline mb-5 overflow-visible" aria-hidden="true">
            <line x1="0" y1="1" x2="80" y2="1" stroke="#B8935A" stroke-width="0.7" vector-effect="non-scaling-stroke"/>
          </svg>

          <!-- Label -->
          <p class="font-sans text-[10px] uppercase tracking-[0.28em] text-ivoire/40 leading-relaxed max-w-[120px]">
            {stat.label}
          </p>

          <!-- Hover gold shimmer -->
          <div class="stat-shimmer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700"
               style="background: radial-gradient(ellipse at 50% 0%, rgba(184,147,90,0.08) 0%, transparent 65%);"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";
  import { drawSVGStagger } from "../lib/svg-draw";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("stats");
      if (!section) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Label
      const label = section.querySelector<HTMLElement>(".stats-label");
      if (label) {
        gsap.to(label, { opacity: 1, y: 0, duration: 0.9, ease: "power3.out",
          scrollTrigger: { trigger: section, start: "top 82%", once: true } });
      }

      // Stat items: 3D flip entry (rotateX from above)
      const items = section.querySelectorAll<HTMLElement>(".stat-item");
      if (!reduced) {
        gsap.fromTo(items,
          { opacity: 0, scale: 0.85, rotateX: -45, z: -120, y: 60 },
          { opacity: 1, scale: 1, rotateX: 0, z: 0, y: 0,
            duration: 1.4, stagger: 0.12, ease: "expo.out",
            scrollTrigger: { trigger: section, start: "top 78%", once: true } }
        );
      }

      // Numeric counters
      section.querySelectorAll<HTMLElement>(".stat-number").forEach((el) => {
        const target = parseFloat(el.getAttribute("data-target") || "0");
        const proxy = { value: 0 };
        ScrollTrigger.create({
          trigger: el,
          start: "top 85%",
          once: true,
          onEnter: () => {
            gsap.to(proxy, {
              value: target,
              duration: 2.2,
              ease: "power2.out",
              onUpdate: () => { el.textContent = Math.floor(proxy.value).toString(); },
              onComplete: () => { el.textContent = target.toString(); },
            });
          },
        });
      });

      // SVG filament draw
      const lines = section.querySelectorAll<SVGGeometryElement>(".stat-underline line");
      if (lines.length) {
        drawSVGStagger(lines, {
          duration: 1.4, ease: "power3.out", stagger: 0.18,
          scrollTrigger: { trigger: section, start: "top 80%", once: true },
        });
      }

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else { setup(); }
  }
</script>

<style>
  .stats-section {
    background: var(--noir-orfevre);
  }

  .stat-item {
    will-change: transform, opacity;
    transform-style: preserve-3d;
    transition: background 0.4s ease;
  }

  .stat-number {
    font-weight: 300;
    will-change: contents;
    letter-spacing: -0.04em;
  }

  .stat-suffix { font-weight: 300; letter-spacing: -0.03em; }
  .stat-underline line { will-change: stroke-dashoffset; }

  @media (max-width: 767px) {
    .stats-section { padding-block: 0; }
    .stat-item { padding-block: 3.5rem; padding-inline: 1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-item { transform: none !important; opacity: 1 !important; }
  }
</style>
