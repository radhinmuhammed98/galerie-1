---
// Section diptyque cinématographique — 2 canvas image-sequences scrubbed en synchro.
// Enhancement: book-fold reveal (rotateY) + gold separator animation + 3D text overlays.

import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

const titleText = lang === 'en' ? "Two gazes, a single quest." : "Deux regards, une même quête.";
const overlay1 = lang === 'en' ? "Light and shadow."        : "Le clair et l'obscur.";
const overlay2 = lang === 'en' ? "Tradition and modernity." : "Tradition et modernité.";
const overlay3 = lang === 'en' ? "Two hands, one vision."   : "Deux mains, une vision.";
---

<section class="diptyque-section relative bg-noir-orfevre" id="diptyque">
  <div class="diptyque-pin sticky top-0 h-screen w-full overflow-hidden">

    <!-- Titre H2 en overlay haut -->
    <div class="absolute top-10 left-0 right-0 z-10 text-center pointer-events-none px-6">
      <h2
        class="diptyque-title text-ivoire font-serif tracking-wide opacity-0 px-6"
        style="font-size: clamp(1.8rem, 4vw, 4.5rem);"
        data-diptyque-title
      >
        {titleText}
      </h2>
    </div>

    <!-- Container split desktop / stack mobile — perspective pour book-fold -->
    <div class="diptyque-panes-wrap absolute inset-0 flex flex-col md:flex-row" style="perspective: 1400px; transform-style: preserve-3d;">

      <!-- Panneau gauche — commence tourné à -25deg -->
      <div class="diptyque-pane diptyque-pane-left relative w-full h-1/2 md:w-1/2 md:h-full overflow-hidden"
           style="transform-origin: right center; transform: rotateY(-28deg); opacity: 0.4;">
        <canvas id="diptyque-canvas-left" class="w-full h-full block"></canvas>
        <!-- Vignette bord gauche -->
        <div class="absolute inset-0 pointer-events-none"
             style="background: linear-gradient(to right, rgba(10,10,10,0.65) 0%, transparent 30%);"></div>
      </div>

      <!-- Panneau droit — commence tourné à +25deg -->
      <div class="diptyque-pane diptyque-pane-right relative w-full h-1/2 md:w-1/2 md:h-full overflow-hidden"
           style="transform-origin: left center; transform: rotateY(28deg); opacity: 0.4;">
        <canvas id="diptyque-canvas-right" class="w-full h-full block"></canvas>
        <div class="absolute inset-0 pointer-events-none"
             style="background: linear-gradient(to left, rgba(10,10,10,0.65) 0%, transparent 30%);"></div>
      </div>
    </div>

    <!-- Séparateur or-fonce animé -->
    <div class="diptyque-divider absolute pointer-events-none" aria-hidden="true">
      <!-- Dot central qui se dilate -->
      <div class="diptyque-divider-dot"></div>
    </div>

    <!-- Overlays textuels — 3D entry -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-20 px-6" style="perspective: 900px;">
      <span data-diptyque-overlay="0"
            class="diptyque-overlay opacity-0 absolute font-serif italic text-ivoire text-center max-w-3xl"
            style="font-size: clamp(1.6rem, 3.5vw, 3.5rem); transform: perspective(900px) rotateX(-18deg) translateZ(-60px);">
        {overlay1}
      </span>
      <span data-diptyque-overlay="1"
            class="diptyque-overlay opacity-0 absolute font-serif italic text-ivoire text-center max-w-3xl"
            style="font-size: clamp(1.6rem, 3.5vw, 3.5rem); transform: perspective(900px) rotateX(-18deg) translateZ(-60px);">
        {overlay2}
      </span>
      <span data-diptyque-overlay="2"
            class="diptyque-overlay opacity-0 absolute font-serif italic text-ivoire text-center max-w-3xl"
            style="font-size: clamp(1.6rem, 3.5vw, 3.5rem); transform: perspective(900px) rotateX(-18deg) translateZ(-60px);">
        {overlay3}
      </span>
    </div>

    <!-- Loader -->
    <div id="diptyque-loader"
         class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[30] text-ivoire/50 text-xs font-sans tracking-[0.3em] uppercase">
      <span id="diptyque-progress">0</span>%
    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";
  import { initDiptyqueSequence } from "../lib/diptyque-sequence";

  const FRAME_COUNT = 100;
  const framePathLeft  = (i: number) => `/images/sequence-diptyque-left/frame_${String(i + 1).padStart(3, "0")}.webp`;
  const framePathRight = (i: number) => `/images/sequence-diptyque-right/frame_${String(i + 1).padStart(3, "0")}.webp`;

  if (typeof window !== "undefined") {
    const setup = () => {
      const canvasLeft  = document.getElementById("diptyque-canvas-left")  as HTMLCanvasElement | null;
      const canvasRight = document.getElementById("diptyque-canvas-right") as HTMLCanvasElement | null;
      const section = document.querySelector(".diptyque-section") as HTMLElement | null;
      const titleEl = document.querySelector<HTMLElement>("[data-diptyque-title]");
      const overlays = document.querySelectorAll<HTMLElement>("[data-diptyque-overlay]");
      const paneLeft = document.querySelector<HTMLElement>(".diptyque-pane-left");
      const paneRight = document.querySelector<HTMLElement>(".diptyque-pane-right");
      const loader = document.getElementById("diptyque-loader");
      const progress = document.getElementById("diptyque-progress");

      if (!canvasLeft || !canvasRight || !section) return;

      section.style.height = "400vh";

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // --- Book-fold reveal: les deux panneaux s'ouvrent comme un livre ---
      if (paneLeft && paneRight && !reduced) {
        gsap.to(paneLeft, {
          rotateY: 0,
          opacity: 1,
          duration: 1.4,
          ease: "power3.out",
          scrollTrigger: {
            trigger: section,
            start: "top 85%",
            once: true,
          },
        });
        gsap.to(paneRight, {
          rotateY: 0,
          opacity: 1,
          duration: 1.4,
          ease: "power3.out",
          delay: 0.08,
          scrollTrigger: {
            trigger: section,
            start: "top 85%",
            once: true,
          },
        });
      } else {
        // Reduced motion: reveal instantly
        if (paneLeft) { paneLeft.style.transform = "none"; paneLeft.style.opacity = "1"; }
        if (paneRight) { paneRight.style.transform = "none"; paneRight.style.opacity = "1"; }
      }

      // --- Titre fade-in avec légère montée Y ---
      if (titleEl) {
        gsap.fromTo(titleEl,
          { opacity: 0, y: 16, rotateX: -10 },
          {
            opacity: 1, y: 0, rotateX: 0,
            duration: 1.2, ease: "power3.out",
            scrollTrigger: { trigger: section, start: "top 75%", toggleActions: "play none none reverse" },
          }
        );
      }

      // --- Overlays 3D (pilotés par onProgress) ---
      initDiptyqueSequence({
        canvasLeft, canvasRight, section,
        framePathLeft, framePathRight,
        frameCount: FRAME_COUNT,
        loaderEl: loader,
        progressEl: progress,
        onProgress: (p) => {
          // 3 overlays successifs, entrée 3D depuis depth
          const ranges: Array<[number, number, number]> = [
            [0.10, 0.27, 0.32],
            [0.40, 0.55, 0.62],
            [0.70, 0.85, 0.92],
          ];
          overlays.forEach((el, i) => {
            const range = ranges[i];
            if (!range) return;
            const [s, peak, e] = range;
            let opacity = 0;
            if (p >= s && p < peak) opacity = (p - s) / (peak - s);
            else if (p >= peak && p < e) opacity = 1 - (p - peak) / (e - peak);
            opacity = Math.max(0, Math.min(1, opacity));

            // 3D: entry from depth
            const rX = -18 * (1 - opacity);
            const tZ = -60 * (1 - opacity);
            const y = (1 - opacity) * 14;
            el.style.opacity = String(opacity);
            el.style.transform = `perspective(900px) rotateX(${rX}deg) translateZ(${tZ}px) translateY(${y}px)`;
          });
        },
      });

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .diptyque-title {
    font-weight: 300;
    text-shadow: 0 4px 28px rgba(0, 0, 0, 0.6);
    will-change: opacity, transform;
    transform-style: preserve-3d;
  }

  .diptyque-overlay {
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.9);
    will-change: opacity, transform;
  }

  /* Panneaux 3D */
  .diptyque-pane {
    will-change: transform, opacity;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  /* Séparateur : ligne verticale desktop, horizontale mobile */
  .diptyque-divider {
    background: rgba(184, 147, 90, 0.40);
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
  }

  .diptyque-divider-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #D4B886;
    box-shadow: 0 0 12px rgba(212, 184, 134, 0.7);
  }

  @media (min-width: 768px) {
    .diptyque-divider {
      top: 0;
      bottom: 0;
      left: 50%;
      right: auto;
      width: 1px;
      height: auto;
      transform: translateX(-0.5px);
    }
  }

  @media (max-width: 767px) {
    .diptyque-pane-left,
    .diptyque-pane-right {
      /* Mobile: rotateX instead of rotateY for vertical stack */
      transform-origin: bottom center !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .diptyque-title, .diptyque-overlay, .diptyque-pane { transition: none; transform: none !important; opacity: 1 !important; }
  }
</style>
