---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

interface GalleryItem { src: string; caption?: string; }
const items: GalleryItem[] = [
  { src: '/images/about/image_5.jpg',  caption: lang === 'en' ? 'Goldsmith workshop'    : 'Atelier d\'orfèvrerie' },
  { src: '/images/about/image_6.jpg',  caption: lang === 'en' ? 'Engraving detail'      : 'Détail de gravure' },
  { src: '/images/about/image_7.jpg',  caption: lang === 'en' ? 'Private collection'    : 'Collection privée' },
  { src: '/images/about/image_8.jpg',  caption: lang === 'en' ? 'Opening night'         : 'Vernissage' },
];
---

<section class="gallery-section relative overflow-hidden" id="gallery">

  <!-- Ghost text background -->
  <div class="gallery-ghost-text" aria-hidden="true">GALERIE</div>

  <div class="gallery-inner max-w-[1800px] mx-auto px-6 md:px-12 pt-28 md:pt-40 pb-24 md:pb-36">

    <!-- Header -->
    <div class="gallery-header flex flex-col md:flex-row justify-between items-end mb-16 md:mb-24">
      <div>
        <p class="gallery-label font-sans text-[10px] uppercase tracking-[0.35em] text-or-fonce mb-5 opacity-0">
          {lang === 'en' ? 'Our collection' : 'Notre collection'}
        </p>
        <h2 class="gallery-h2 font-serif tracking-tighter leading-[0.9]" style="font-size: clamp(3.5rem, 7vw, 8rem);">
          {t['savoir.text']}
        </h2>
      </div>
      <p class="gallery-sub font-sans text-xs uppercase tracking-[0.28em] text-or-fonce mt-8 md:mt-0 max-w-xs text-right opacity-0">
        {t['quote.text']}
      </p>
    </div>

    <!-- Grid desktop: 2-col staggered | mobile: 1-col -->
    <div class="gallery-grid grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 lg:gap-28">
      {items.map((item, index) => (
        <div
          class={`gallery-item relative overflow-hidden group cursor-pointer ${index % 2 !== 0 ? 'md:mt-36' : ''}`}
          data-cursor="image"
          data-cursor-label="voir"
          data-caption={item.caption}
          tabindex="0"
          role="button"
          aria-label={item.caption ?? 'Savoir-faire'}
          style="perspective: var(--perspective-card);"
        >
          <!-- Card inner (3D tilt target) -->
          <div class="gallery-card-inner aspect-[3/4] w-full bg-gris-pierre relative overflow-hidden rounded-[20px]" style="transform-style: preserve-3d;">
            <img
              src={item.src}
              alt={item.caption ?? 'Savoir-faire'}
              class="object-cover w-full h-full parallax-img transition-transform duration-700 group-hover:scale-[1.06]"
              loading="lazy"
            />
            <!-- Sheen overlay on hover -->
            <div class="gallery-card-sheen absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                 style="background: linear-gradient(135deg, rgba(212,184,134,0.12) 0%, transparent 55%);"></div>
            <!-- Gold veil -->
            <div class="gallery-item__veil absolute inset-0 bg-or-fonce/0 group-hover:bg-or-fonce/8 transition-colors duration-700 pointer-events-none"></div>
          </div>

          <!-- Caption -->
          {item.caption && (
            <div class="gallery-item__caption absolute bottom-5 left-5 right-5 text-ivoire opacity-0 translate-y-2 transition-all duration-500 ease-out font-serif italic text-base md:text-lg pointer-events-none px-3 py-2 rounded-[12px]"
                 style="background: rgba(10,10,10,0.45); backdrop-filter: blur(16px);">
              {item.caption}
            </div>
          )}

          <!-- Index number -->
          <div class="gallery-item-index absolute top-5 right-5 font-sans text-[10px] tracking-[0.28em] text-ivoire/40 z-10">
            {String(index + 1).padStart(2, '0')}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";
  import { revealLetters } from "../lib/text-reveal";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("gallery");
      if (!section || section.dataset.galleryBound === "true") return;
      section.dataset.galleryBound = "true";

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isFine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

      // --- Label + sub fade in ---
      const label = section.querySelector<HTMLElement>(".gallery-label");
      const sub = section.querySelector<HTMLElement>(".gallery-sub");
      gsap.to([label, sub], { opacity: 1, y: 0, duration: 0.9, ease: "power3.out", stagger: 0.15,
        scrollTrigger: { trigger: section, start: "top 80%", once: true } });

      // --- H2 letter reveal ---
      const h2 = section.querySelector<HTMLElement>(".gallery-h2");
      if (h2) revealLetters(h2, { stagger: 0.022, duration: 0.65, scrollTrigger: { start: "top 80%", once: true } });

      // --- Items: 3D entry from depth ---
      const items = section.querySelectorAll<HTMLElement>(".gallery-item");
      const cardInners = section.querySelectorAll<HTMLElement>(".gallery-card-inner");
      const images = section.querySelectorAll<HTMLImageElement>(".parallax-img");

      if (!reduced && items.length) {
        gsap.set(items, { opacity: 0, y: 80, rotateX: -18, z: -120 });
        gsap.set(images, { scale: 1.1, transformOrigin: "center" });

        gsap.to(items, {
          opacity: 1, y: 0, rotateX: 0, z: 0,
          duration: 1.15, stagger: 0.14, ease: "power4.out",
          scrollTrigger: { trigger: section.querySelector(".gallery-grid") ?? section, start: "top 78%", once: true },
        });
        gsap.to(images, { scale: 1, duration: 1.6, stagger: 0.14, ease: "power2.out",
          scrollTrigger: { trigger: section.querySelector(".gallery-grid") ?? section, start: "top 78%", once: true } });
      } else if (items.length) {
        gsap.set(items, { opacity: 1 });
      }

      // --- Parallax on images ---
      images.forEach((img) => {
        if (!img.parentElement) return;
        gsap.fromTo(img, { y: -28 }, { y: 28, ease: "none",
          scrollTrigger: { trigger: img.parentElement, start: "top bottom", end: "bottom top", scrub: true } });
      });

      // --- 3D Mouse tilt on desktop ---
      if (isFine && !reduced) {
        items.forEach((item) => {
          const inner = item.querySelector<HTMLElement>(".gallery-card-inner");
          if (!inner) return;
          item.addEventListener("mousemove", (e) => {
            const rect = item.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width  - 0.5;  // -0.5 → 0.5
            const y = (e.clientY - rect.top)  / rect.height - 0.5;
            gsap.to(inner, { rotateY: x * 14, rotateX: -y * 10, z: 20,
              duration: 0.4, ease: "power2.out", overwrite: "auto" });
          }, { passive: true });
          item.addEventListener("mouseleave", () => {
            gsap.to(inner, { rotateY: 0, rotateX: 0, z: 0, duration: 0.6, ease: "power3.out" });
          });
        });
      }

      // --- Caption reveal on hover ---
      items.forEach((item) => {
        const caption = item.querySelector<HTMLElement>(".gallery-item__caption");
        const show = () => { if (caption) gsap.to(caption, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out", overwrite: "auto" }); };
        item.addEventListener("mouseenter", show);
        item.addEventListener("focus", show);
        item.addEventListener("click", show);
      });

      // --- Ghost text parallax ---
      const ghost = section.querySelector<HTMLElement>(".gallery-ghost-text");
      if (ghost && !reduced) {
        gsap.set(ghost, { xPercent: -50, yPercent: -50 });
        gsap.to(ghost, { yPercent: -70, rotateX: 15, rotateY: -8, scale: 0.88, ease: "none",
          scrollTrigger: { trigger: section, start: "top bottom", end: "bottom top", scrub: 1.5 } });
      }

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else { setup(); }
  }
</script>

<style>
  .gallery-section {
    background:
      radial-gradient(circle at 14% 6%, rgba(184, 147, 90, 0.18), transparent 34rem),
      radial-gradient(circle at 82% 22%, rgba(143, 95, 61, 0.14), transparent 28rem),
      linear-gradient(180deg, #F4EFE6 0%, #EFE5D5 52%, #E9DDC9 100%);
    color: var(--noir-orfevre);
  }

  .gallery-ghost-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(14rem, 38vw, 48rem);
    font-weight: 300;
    line-height: 0.85;
    letter-spacing: -0.06em;
    color: #0A0A0A;
    opacity: 0.032;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    will-change: transform;
    z-index: 0;
  }

  .gallery-inner { position: relative; z-index: 1; }

  .gallery-item {
    transform-style: preserve-3d;
    will-change: transform, opacity;
    cursor: pointer;
  }

  .gallery-card-inner {
    will-change: transform;
    transition: box-shadow 0.45s ease;
    box-shadow: 0 24px 80px rgba(10, 10, 10, 0.14);
  }

  .gallery-item:hover .gallery-card-inner,
  .gallery-item:focus-visible .gallery-card-inner {
    box-shadow: 0 40px 100px rgba(10, 10, 10, 0.26);
  }

  .gallery-item__caption {
    will-change: opacity, transform;
  }

  .gallery-item-index {
    font-weight: 300;
  }

  /* Hover: non-hovered items fade */
  @media (hover: hover) and (pointer: fine) {
    .gallery-grid:hover .gallery-item:not(:hover) {
      filter: saturate(0.80) brightness(0.90);
      transition: filter 0.4s ease;
    }
    .gallery-item:hover { filter: saturate(1.04) brightness(1); }
  }

  @media (max-width: 767px) {
    #gallery { padding-block: 5rem; }

    .gallery-grid { gap: 1.2rem; }

    .gallery-card-inner {
      border: 1px solid rgba(10, 10, 10, 0.08);
      box-shadow: 0 18px 50px rgba(10, 10, 10, 0.10);
    }

    .gallery-ghost-text { font-size: 60vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-item, .gallery-card-inner, .gallery-item__caption { transition: none; }
  }
</style>
