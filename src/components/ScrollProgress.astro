---
// Indicateur de progression du scroll global, fin trait or-fonce en haut de l'écran.
// Discret : opacity 0.6, fade out quand on est tout en haut.
---
<div id="scroll-progress" class="scroll-progress" aria-hidden="true">
  <div class="scroll-progress__bar"></div>
</div>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";

  if (typeof window !== "undefined") {
    const setup = () => {
      const root = document.getElementById("scroll-progress");
      const bar = root?.querySelector<HTMLElement>(".scroll-progress__bar");
      if (!root || !bar) return;

      // Update sur scroll Lenis ou natif. Lenis est attaché à window APRÈS ce script,
      // on retry pour s'abonner à son event 'scroll' dès qu'il est dispo.
      const update = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const y = (window as any).lenis?.scroll ?? window.scrollY;
        const p = max > 0 ? y / max : 0;
        bar.style.transform = `scaleX(${p})`;
        root.style.opacity = y > 80 ? "0.6" : "0";
      };

      window.addEventListener("scroll", update, { passive: true });
      update();

      // Attache l'event Lenis dès qu'il est disponible (init différé dans BaseLayout)
      let attached = false;
      const tryAttach = () => {
        const lenis = (window as any).lenis;
        if (!attached && lenis && typeof lenis.on === "function") {
          lenis.on("scroll", update);
          attached = true;
          return;
        }
        if (!attached) setTimeout(tryAttach, 100);
      };
      tryAttach();

      void gsap;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
    void ScrollTrigger;
    void gsap;
  }
</script>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    z-index: 100;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .scroll-progress__bar {
    width: 100%;
    height: 100%;
    background: #B8935A;
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-progress { transition: none; }
  }
</style>
