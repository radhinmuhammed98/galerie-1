---
// Indicateur "Découvrir" sous le hero — ligne verticale + point lumineux qui descend en boucle.
// Disparaît dès que l'utilisateur scrolle au-delà de 100px.
---
<div id="hero-scroll-indicator" class="hero-scroll-indicator" aria-hidden="true">
  <span class="hero-scroll-indicator__label">Découvrir</span>
  <svg viewBox="0 0 2 60" width="2" height="60" class="hero-scroll-indicator__line" aria-hidden="true">
    <line x1="1" y1="0" x2="1" y2="60" stroke="rgba(212,184,134,0.25)" stroke-width="1" />
    <circle r="2" cx="1" cy="0" fill="#D4B886" class="hero-scroll-indicator__dot" />
  </svg>
</div>

<script>
  import { gsap } from "../lib/gsap-config";

  if (typeof window !== "undefined") {
    const setup = () => {
      const root = document.getElementById("hero-scroll-indicator");
      const dot = root?.querySelector<SVGCircleElement>(".hero-scroll-indicator__dot");
      if (!root || !dot) return;

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Boucle infinie : le point descend, fade en bas, reset en haut
      if (!prefersReducedMotion) {
        gsap.to(dot, {
          attr: { cy: 60 },
          duration: 2.4,
          ease: "power2.inOut",
          repeat: -1,
          yoyo: false,
          onRepeat: () => { dot.setAttribute("cy", "0"); },
        });
        gsap.to(dot, {
          opacity: 0,
          duration: 0.6,
          ease: "power2.out",
          repeat: -1,
          repeatDelay: 1.8,
        });
      }

      // Update sur scroll Lenis ou natif (Lenis attaché à window après ce script)
      const update = () => {
        const y = (window as any).lenis?.scroll ?? window.scrollY;
        root.style.opacity = y > 100 ? "0" : "1";
      };
      window.addEventListener("scroll", update, { passive: true });
      update();

      let attached = false;
      const tryAttach = () => {
        const lenis = (window as any).lenis;
        if (!attached && lenis && typeof lenis.on === "function") {
          lenis.on("scroll", update);
          attached = true;
          return;
        }
        if (!attached) setTimeout(tryAttach, 100);
      };
      tryAttach();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .hero-scroll-indicator {
    position: absolute;
    bottom: 6vh;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    opacity: 1;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 4;
  }
  .hero-scroll-indicator__label {
    font-family: "Inter", sans-serif;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(244, 239, 230, 0.65);
    font-weight: 300;
  }
  .hero-scroll-indicator__line { display: block; overflow: visible; }
  .hero-scroll-indicator__dot { will-change: cy, opacity; }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-indicator__dot { animation: none; }
  }
</style>
