---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;
---

<section class="scroll-video-section relative bg-noir-orfevre" id="savoir-faire">
  <!-- Conteneur sticky -->
  <div class="scroll-video-pin sticky top-0 h-screen w-full overflow-hidden flex items-center justify-center">

    <!-- Letterbox bars cinématiques (glissent depuis top/bottom) -->
    <div class="letterbox-bar-top" id="sv-bar-top" aria-hidden="true"></div>
    <div class="letterbox-bar-bottom" id="sv-bar-bottom" aria-hidden="true"></div>

    <!-- Particules dorées -->
    <div id="scroll-video-particles" class="absolute inset-0 z-[2] pointer-events-none opacity-40 mix-blend-screen"></div>

    <!-- Canvas image-sequence (inchangé) -->
    <canvas
      id="scroll-video-canvas"
      class="scroll-video-canvas absolute inset-0 h-full w-full md:inset-auto md:aspect-[16/9] md:w-[min(96vw,170vh)] md:max-h-[95vh] z-0 md:rounded-[20px] shadow-2xl border border-ivoire/10"
      style="opacity: 0;"
    ></canvas>

    <!-- Loader -->
    <div id="scroll-video-loader" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[4] text-ivoire/50 text-xs font-sans tracking-[0.3em] uppercase">
      <span id="scroll-video-progress">0</span>%
    </div>

    <!-- OVERLAY 1 : Savoir-faire intro (3D entry) -->
    <div class="scroll-video-overlay-1 absolute inset-0 flex flex-col items-center justify-center text-center px-6 z-[3] pointer-events-none" style="perspective: var(--perspective-hero);">
      <h2 class="sv-overlay-text text-ivoire font-serif text-center max-w-4xl leading-[1.0] px-4 select-none" style="font-size: clamp(2.6rem, 5.5vw, 7rem); transform: perspective(1000px) rotateX(-18deg) translateZ(-80px); opacity: 0;">
        {t['savoir.text']}
      </h2>
    </div>

    <!-- OVERLAY 2 : Citation (3D entry) -->
    <div class="scroll-video-overlay-2 absolute inset-0 flex flex-col items-center justify-center text-center px-6 z-[3] pointer-events-none opacity-0">
      <h2 class="sv-overlay-text text-ivoire font-serif text-center max-w-4xl leading-[1.0] px-4 select-none" style="font-size: clamp(2.6rem, 5.5vw, 7rem);">
        {t['quote.text']}
      </h2>
    </div>

    <!-- OVERLAY 3 : caption droite (derniers 15% du scroll) -->
    <div class="scroll-video-overlay-3 absolute bottom-14 right-6 md:right-12 z-[9] pointer-events-none opacity-0 text-right">
      <p class="font-sans text-[10px] uppercase tracking-[0.28em] text-or-fonce mb-1">
        {lang === 'en' ? 'Savoir-faire' : 'Savoir-faire'}
      </p>
      <p class="font-serif italic text-ivoire/80 text-lg md:text-xl" style="transform: translateX(30px);">
        {lang === 'en' ? 'Where excellence is born.' : 'Là où naît l\'excellence.'}
      </p>
    </div>

  </div>
</section>

<script>
  import { gsap } from "../lib/gsap-config";
  import { initScrollSequence } from "../lib/scroll-sequence";
  import { initParticles } from "./ParticlesBackground";

  const SAVOIR_FRAME_COUNT = 100;
  const savoirFramePath = (i: number) =>
    `/images/sequence/savoirfaire/frame_${String(i + 1).padStart(3, "0")}.webp`;

  if (typeof window !== "undefined") {
    const setup = () => {
      const canvas = document.getElementById("scroll-video-canvas") as HTMLCanvasElement | null;
      const section = document.querySelector(".scroll-video-section") as HTMLElement | null;
      const overlay1 = document.querySelector(".scroll-video-overlay-1") as HTMLElement | null;
      const overlay2 = document.querySelector(".scroll-video-overlay-2") as HTMLElement | null;
      const overlay3 = document.querySelector(".scroll-video-overlay-3") as HTMLElement | null;
      const ov1Text = overlay1?.querySelector<HTMLElement>(".sv-overlay-text");
      const loader = document.getElementById("scroll-video-loader");
      const progress = document.getElementById("scroll-video-progress");
      const particlesContainer = document.getElementById("scroll-video-particles");
      const barTop = document.getElementById("sv-bar-top");
      const barBottom = document.getElementById("sv-bar-bottom");

      if (!canvas || !section || !overlay1 || !overlay2) return;

      const isMobile = window.matchMedia("(max-width: 767px), (pointer: coarse)").matches;
      section.style.height = isMobile ? "420vh" : "550vh";

      if (particlesContainer) initParticles(particlesContainer, { count: 60 });

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // --- Letterbox bars: entrent depuis haut et bas au scroll 0→5% ---
      // Gérées dans onProgress

      if (prefersReducedMotion) {
        gsap.set(overlay1, { opacity: 1 });
        if (ov1Text) { ov1Text.style.opacity = "1"; ov1Text.style.transform = "none"; }
        gsap.set(overlay2, { opacity: 0 });
      }

      initScrollSequence({
        canvas, section,
        framePath: savoirFramePath,
        frameCount: SAVOIR_FRAME_COUNT,
        loaderEl: loader,
        progressEl: progress,
        onProgress: (p) => {
          // Canvas fade-in
          let cOpacity = 1;
          if (p < 0.10) cOpacity = p / 0.10;
          canvas.style.opacity = String(Math.max(0, Math.min(1, cOpacity)));

          // Letterbox bars: scaleY 0→1 entre 0-0.06
          const barScale = Math.min(1, p / 0.06);
          if (barTop) barTop.style.transform = `scaleY(${barScale})`;
          if (barBottom) barBottom.style.transform = `scaleY(${barScale})`;

          // Overlay 1 (savoir-faire) — 3D entry rotateX
          let o1 = 0;
          if (p < 0.12) o1 = 0;
          else if (p < 0.24) o1 = (p - 0.12) / 0.12;
          else if (p < 0.38) o1 = 1;
          else if (p < 0.52) o1 = 1 - (p - 0.38) / 0.14;
          else o1 = 0;
          o1 = gsap.utils.clamp(0, 1, o1);
          if (ov1Text) {
            const rX = -18 * (1 - o1);
            const tZ = -80 * (1 - o1);
            ov1Text.style.opacity = String(o1);
            ov1Text.style.transform = `perspective(1000px) rotateX(${rX}deg) translateZ(${tZ}px) translateY(${-50 * (1 - o1)}px)`;
          }
          gsap.set(overlay1, { opacity: o1 > 0 ? 1 : 0 });

          // Overlay 2 (citation) — 3D entry
          let o2 = 0;
          if (p >= 0.58 && p < 0.70) o2 = (p - 0.58) / 0.12;
          else if (p >= 0.70 && p < 0.92) o2 = 1;
          else if (p >= 0.92) o2 = 1 - (p - 0.92) / 0.08;
          o2 = gsap.utils.clamp(0, 1, o2);
          gsap.set(overlay2, {
            opacity: o2,
            y: (1 - o2) * 80 - (p > 0.92 ? 50 * (p - 0.92) / 0.08 : 0),
            rotateX: -14 * (1 - o2),
            scale: 0.95 + 0.05 * o2,
          });

          // Overlay 3 (caption droite) — slide from right en fin de section
          let o3 = 0;
          if (p >= 0.84) o3 = (p - 0.84) / 0.10;
          o3 = gsap.utils.clamp(0, 1, o3);
          if (overlay3) {
            const captionText = overlay3.querySelector<HTMLElement>("p:last-child");
            overlay3.style.opacity = String(o3);
            if (captionText) captionText.style.transform = `translateX(${30 * (1 - o3)}px)`;
          }
        },
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .scroll-video-section h2 {
    font-weight: 300;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
  }

  .sv-overlay-text {
    will-change: transform, opacity;
    transform-origin: center bottom;
  }

  .scroll-video-overlay-1,
  .scroll-video-overlay-2 {
    transform-style: preserve-3d;
  }

  @media (max-width: 767px) {
    .scroll-video-pin {
      height: 100svh;
      min-height: 100svh;
    }

    .scroll-video-pin::after {
      content: "";
      position: absolute;
      inset: 22px 14px;
      z-index: 1;
      pointer-events: none;
      border: 1px solid rgba(244, 239, 230, 0.10);
      background: linear-gradient(180deg, rgba(10, 10, 10, 0.04), rgba(10, 10, 10, 0.28));
      box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(1px);
      -webkit-backdrop-filter: blur(1px);
      border-radius: 20px;
    }

    .scroll-video-overlay-1 h2,
    .scroll-video-overlay-2 h2 {
      max-width: 92vw;
      font-size: clamp(2.35rem, 11vw, 4.2rem) !important;
      line-height: 1;
      text-wrap: balance;
    }

    .scroll-video-overlay-3 {
      right: 1rem;
      bottom: 4.5rem;
    }

    #scroll-video-loader {
      bottom: max(1.25rem, env(safe-area-inset-bottom));
      padding: 0.65rem 0.8rem;
      border: 1px solid rgba(212, 184, 134, 0.16);
      background: rgba(10, 10, 10, 0.42);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-radius: 12px;
    }
  }
</style>
